MODEL_PROVIDER=qwen
SECOPS_MODEL=qwen3.6-max-preview
MODEL_API_KEY=replace-with-your-provider-key
MODEL_BASE_URL=https://your-openai-compatible-provider/v1
SECOPS_CONFIG_PATH=secops.config.json
SECOPS_ACTION_LEVEL=sandbox
SECOPS_RUNTIME_CONFIG_PATH=runtime/config/settings.json
SECOPS_SANDBOX_ROOT=runtime/sandbox
SECOPS_AUDIT_LOG_PATH=runtime/audit/events.jsonl
SECOPS_APPROVAL_STORE_PATH=runtime/approvals/pending.json
# 嵌入式 PGlite durable sessions：data dir + 开关（memory:// 为内存模式，off 禁用）
SECOPS_DATA_DIR=runtime/pgdata
SECOPS_DURABLE_SESSIONS=on
SECOPS_ALLOWED_HOSTS=localhost,127.0.0.1,::1
SECOPS_ALLOWED_ORIGINS=http://localhost:5317,http://127.0.0.1:5317
SECOPS_API_TOKEN=
PORT=4317
SECOPS_BIND_HOST=127.0.0.1
WAZUH_API_URL=https://wazuh.example.local:55000
WAZUH_API_USER=secops-agent
WAZUH_API_PASSWORD=replace-with-wazuh-api-password
WAZUH_TLS_VERIFY=true
WAZUH_CA_CERT_PATH=
WAZUH_REQUEST_TIMEOUT_MS=15000
WAZUH_BLOCK_IP_COMMANDS=firewall-drop,firewalld-drop,route-null,netsh
WAZUH_MAX_BLOCK_DURATION_SECONDS=86400
WAZUH_INDEXER_URL=https://wazuh-indexer.example.local:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=replace-with-wazuh-indexer-password
WAZUH_ALERTS_INDEX=wazuh-alerts-*
WAZUH_INDEXER_TLS_VERIFY=true
WAZUH_INDEXER_CA_CERT_PATH=
WAZUH_INDEXER_REQUEST_TIMEOUT_MS=15000
